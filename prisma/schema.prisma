generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Transferencia {
  id                  Int      @id @default(autoincrement())
  fecha               DateTime
  refCorriente        String
  refOrigen           String
  importe             Float
  tipo                String
  source              String   @default("scraper")
  nombreOrdenante     String   @default("")
  ciOrdenante         String   @default("")
  tarjetaOrdenante    String   @default("")
  cuentaOrdenante     String   @default("")
  idCubacel           String   @default("")
  telefonoOrdenante   String   @default("")
  canalEmision        String   @default("")
  sucursalOrdenante   String   @default("")
  numDebito           String   @default("")
  tipoServicio        String   @default("")
  fechaFactura        String   @default("")
  formato             String   @default("desconocido")
  observacionesRaw    String   @default("")
  createdAt           DateTime @default(now())

  codigoConfirmacion  String?   @unique
  confirmedAt         DateTime?
  confirmedBy         String?

  claimedAt           DateTime?
  claimedBy           String?

  searchAttempts      Int      @default(0)
  matchType           String?
  nivelConfianza      Int?

  solicitud           Solicitud?

  @@unique([refCorriente, refOrigen, importe, fecha, tipo])
  @@index([fecha])
  @@index([nombreOrdenante])
  @@index([importe])
  @@index([claimedAt])
  @@index([matchType])
}

model ApiToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  name      String   @default("")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model MonitorConfig {
  id                 Int      @id @default(1)
  enabled            Boolean  @default(true)
  interval_minutes   Int      @default(5)
  telegram_bot_token String?
  telegram_chat_id   String?
  telegram_topic_id  Int?
  telegram_webhook_url String?
  updatedAt          DateTime @updatedAt
}

model OdooConfig {
  id          Int      @id @default(1)
  api_url     String   @default("")
  api_key     String   @default("")
  updatedAt   DateTime @updatedAt
}

model BankStatus {
  id             Int       @id @default(1)
  online         Boolean   @default(false)
  last_check     DateTime?
  last_online    DateTime?
  fecha_contable String?
  updatedAt      DateTime  @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String   @default("")
  picture   String   @default("")
  role      String   @default("viewer")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  uploads   StatementUpload[]
}

model StatementUpload {
  id              Int      @id @default(autoincrement())
  filename        String
  fileHash        String   @unique
  filesProcessed  Int
  totalRecords    Int
  nuevas          Int
  fechaDesde      String
  fechaHasta      String
  saldoInicial    Float?
  saldoFinal      Float?
  createdAt       DateTime @default(now())

  uploadedBy      Int
  user            User     @relation(fields: [uploadedBy], references: [id])
}

// ── Solicitudes GT (sistema distribuido offline-first) ──

model Solicitud {
  id                Int       @id @default(autoincrement())
  codigo            String    @unique
  sedeId            String
  version           Int       @default(1)

  // Cliente
  clienteNombre     String
  clienteCi         String
  clienteCuenta     String
  clienteTelefono   String?
  odooPartnerId     Int?

  // Transferencia (SMS)
  monto             Decimal   @db.Decimal(16, 2)
  canalEmision      String?
  transferCode      String?
  notas             String?
  fingerprint       String?

  // Estados separados
  workflowStatus    String    @default("pending")   // pending | claimed | cancelled
  reconStatus       String    @default("unmatched")  // unmatched | suggested | matched

  // Creación
  creadoAt          DateTime
  creadoPor         String

  // Reclamación
  reclamadaAt       DateTime?
  reclamadaPor      String?

  // Conciliación con banco
  transferenciaId   Int?      @unique
  transferencia     Transferencia? @relation(fields: [transferenciaId], references: [id])
  conciliadaAt      DateTime?
  conciliadaPor     String?
  matchNivel        Int?

  // Anulación
  anuladaAt         DateTime?
  anuladaPor        String?
  motivoAnulacion   String?

  // Cross-sede duplicate detection
  crossDupOf        String?

  // Sync
  syncReceivedAt    DateTime  @default(now())
  lastEventId       String?

  @@index([workflowStatus])
  @@index([reconStatus])
  @@index([workflowStatus, reconStatus])
  @@index([sedeId])
  @@index([sedeId, creadoAt])
  @@index([clienteCi])
  @@index([clienteCuenta])
  @@index([monto])
  @@index([fingerprint])
}

model SolicitudEvent {
  id              Int       @id @default(autoincrement())
  eventId         String    @unique
  solicitudCodigo String
  eventType       String    // CREATED | CLAIMED | ANNULLED
  payload         Json
  payloadHash     String?   // SHA256 truncado para integridad
  sedeId          String
  createdAt       DateTime
  receivedAt      DateTime  @default(now())

  @@index([solicitudCodigo])
  @@index([sedeId, createdAt])
}

model SolicitudSnapshot {
  id              Int       @id @default(autoincrement())
  solicitudCodigo String
  snapshotAt      DateTime  @default(now())
  version         Int
  state           Json
  lastEventId     String

  @@index([solicitudCodigo])
}

model Invitation {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  role      String    @default("viewer")
  invitedBy Int?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}
